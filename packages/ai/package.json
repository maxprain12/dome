{
  "name": "@dome/ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Multi-provider LLM layer (SDK connectors). Node-only.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./oauth": {
      "types": "./dist/oauth.d.ts",
      "import": "./dist/oauth.js",
      "require": "./dist/oauth.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.7",
    "vitest": "^3.2.7"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.114.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1094.0",
    "@google/genai": "^1.52.0",
    "@mistralai/mistralai": "^2.5.0",
    "@smithy/node-http-handler": "^4.9.10",
    "@smithy/types": "^4.16.1",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "openai": "^6.49.0",
    "partial-json": "^0.1.7",
    "typebox": "^1.3.8"
  }
}
