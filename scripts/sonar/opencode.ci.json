{
  "$schema": "https://opencode.ai/config.json",
  "model": "minimax/MiniMax-M3",
  "agent": {
    "sonar-fix": {
      "mode": "primary",
      "description": "Sonar quality loop — minimal targeted fixes for CI",
      "model": "minimax/MiniMax-M3",
      "prompt": "{file:../../.cursor/prompts/sonar-fix-batch-ci.md}",
      "steps": 40,
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": {
          "*": "deny",
          "bash scripts/jenkins/verify-batch-pr.sh": "allow",
          "bash scripts/jenkins/verify-batch-pr.sh *": "allow",
          "pnpm *": "allow",
          "npm *": "allow",
          "node *": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny",
        "todowrite": "deny",
        "skill": "deny"
      }
    },
    "sonar-reviewer": {
      "mode": "primary",
      "description": "Sonar quality loop — read-only diff reviewer before PR",
      "model": "minimax/MiniMax-M3",
      "prompt": "{file:../../.cursor/prompts/sonar-review-batch-ci.md}",
      "steps": 20,
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": {
          "*": "deny",
          "git diff": "allow",
          "git diff *": "allow",
          "git diff --stat": "allow",
          "git diff --stat *": "allow",
          "git diff --name-only": "allow",
          "git diff --name-only *": "allow",
          "pnpm run typecheck": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny",
        "todowrite": "deny",
        "skill": "deny"
      }
    }
  },
  "provider": {
    "minimax": {
      "options": {
        "apiKey": "{env:MINIMAX_API_KEY}"
      }
    }
  }
}
