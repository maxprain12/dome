{
  "$schema": "https://opencode.ai/config.json",
  "model": "minimax/MiniMax-M3",
  "agent": {
    "sonar-fix": {
      "mode": "primary",
      "description": "Sonar quality loop — minimal targeted fixes for CI",
      "model": "minimax/MiniMax-M3",
      "prompt": "{file:../../.cursor/prompts/sonar-fix-batch-ci.md}",
      "steps": 40,
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": {
          "*": "deny",
          "pnpm *": "allow",
          "npm *": "allow",
          "node *": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny",
        "todowrite": "deny",
        "skill": "deny"
      }
    }
  },
  "provider": {
    "minimax": {
      "options": {
        "apiKey": "{env:MINIMAX_API_KEY}"
      }
    }
  }
}
