    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "diff": "^8.0.4",
    "dompurify": "^3.4.0",
    "driver.js": "^1.4.0",
    "electron-ollama": "^0.1.25",
    "electron-updater": "^6.7.3",
    "emoji-mart": "^5.6.0",
    "fix-path": "^4.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "fractional-indexing-jittered": "^1.0.0",
    "framer-motion": "^12.34.3",
    "html-to-docx": "^1.8.0",
    "i18next": "^25.10.10",
    "image-dimensions": "^2.5.0",
    "jotai": "^2.19.1",
    "jszip": "^3.10.1",
    "katex": "0.16.27",
    "langchain": "^1.3.3",
    "linkedom": "^0.18.12",
    "llm-chunk": "^0.0.1",
    "lodash": "^4.17.21",
    "lowlight": "^3.1.0",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.11.0",
    "mantine-form-zod-resolver": "^1.3.0",
    "marked": "^17.0.6",
    "mermaid": "^11.14.0",
    "node-pty": "^1.1.0",
    "papaparse": "^5.5.3",
    "path-to-regexp": "^6.3.0",
    "pdfjs-dist": "^5.6.205",
    "picomatch": "^2.3.2",
    "playwright": "^1.58.2",
    "posthog-js": "^1.369.2",
    "pptx-preview": "^1.0.7",
    "pptxgenjs": "^3.12.0",
    "protobufjs": "^7.5.5",
    "pyodide": "^0.29.0",
    "qrcode-terminal": "^0.12.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.0",
    "react-clear-modal": "^2.0.19",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.0",
    "react-grid-layout": "^2.2.3",
    "react-i18next": "^16.6.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.1",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "rfc6902": "^5.2.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.1",
    "tar": "^7.5.7",
    "tippy.js": "^6.3.7",
    "tiptap-extension-global-drag-handle": "^0.1.18",
    "turndown": "^7.2.4",
    "xlsx": "^0.18.5",
    "yauzl": "^3.2.0",
