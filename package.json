{
  "name": "dome",
  "version": "2.7.5",
  "description": "Aplicación de escritorio inteligente para gestión de conocimiento e investigación",
  "author": "Dome Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxprain12/dome"
  },
  "main": "electron/main.cjs",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "pnpm run build:packages && pnpm run build:prompt-assembler && concurrently \"pnpm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development NODE_OPTIONS=--max-old-space-size=4096 electron .\"",
    "electron:build": "pnpm run build:packages && pnpm run materialize:workspace-deps && pnpm run build && pnpm run rebuild:natives && pnpm run verify:workspace-deps && pnpm run verify:natives && node scripts/embed-env.cjs && cross-env DEBUG= electron-builder",
    "electron:build:verbose": "pnpm run build:packages && pnpm run materialize:workspace-deps && pnpm run build && pnpm run rebuild:natives && pnpm run verify:workspace-deps && pnpm run verify:natives && node scripts/embed-env.cjs && cross-env DEBUG=electron-builder electron-builder",
    "electron:pack": "pnpm run build:packages && pnpm run materialize:workspace-deps && pnpm run verify:workspace-deps && cross-env DEBUG= electron-builder",
    "electron:pack:verbose": "cross-env DEBUG=electron-builder electron-builder",
    "rebuild:natives": "electron-rebuild -f -w=better-sqlite3,sharp,@ffmpeg-installer/ffmpeg,@napi-rs/canvas,@lancedb/lancedb",
    "verify:natives": "node scripts/verify-natives.cjs",
    "verify:sentry-build": "node scripts/verify-sentry-build.cjs",
    "copy:pdf-worker": "node scripts/copy-pdf-worker.cjs",
    "patch:pptx-preview": "node scripts/patch-pptx-preview.mjs",
    "postinstall": "electron-builder install-app-deps && pnpm run build:packages && pnpm run rebuild:natives && pnpm run copy:pdf-worker && pnpm run patch:pptx-preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app/",
    "depcruise": "depcruise app --config .dependency-cruiser.cjs",
    "generate:ipc-inventory": "node scripts/generate-ipc-inventory.mjs",
    "check:ipc-inventory": "node scripts/generate-ipc-inventory.mjs --check",
    "check:ipc-zod": "node scripts/check-ipc-zod.mjs",
    "check:tool-coverage": "node scripts/verify-tool-coverage.mjs",
    "check:design-system": "node scripts/check-hardcoded-colors.mjs",
    "check:asar-unpack": "node scripts/check-asar-unpack.cjs",
    "test:db": "tsx scripts/test-db.ts",
    "test:filesystem-tools": "node --test scripts/test-filesystem-tools.mjs",
    "test:feeders": "node --test scripts/test-feeders.mjs",
    "test:web-search": "node --test scripts/test-web-search.mjs",
    "test:security": "node --test electron/__tests__/shell-policy.test.mjs electron/__tests__/url-guard.test.mjs electron/__tests__/migration-backup.test.mjs electron/__tests__/db-backup.test.mjs electron/__tests__/settings-secrets.test.mjs electron/__tests__/security-path.test.mjs electron/__tests__/logger.test.mjs electron/__tests__/tool-call-policy.test.mjs electron/__tests__/run-retention.test.mjs electron/__tests__/run-recovery.test.mjs electron/__tests__/himalaya-binary.test.mjs electron/__tests__/error-notify.test.mjs electron/__tests__/workflow-dag.test.mjs electron/__tests__/provider-keys.test.mjs electron/__tests__/run-helpers.test.mjs electron/__tests__/ffmpeg-paths.test.mjs electron/__tests__/tool-result-cap.test.mjs",
    "test": "pnpm run test:security && pnpm --filter @dome/agent-core run test",
    "test:studio": "node scripts/test-studio-validators.mjs",
    "test:studio:tools": "node scripts/test-studio-tools.mjs",
    "test:learn:kpis": "node scripts/test-learn-kpis.mjs",
    "test:generate:wizard": "node scripts/test-generate-wizard.mjs",
    "test:multimodal": "node scripts/test-message-multimodal.mjs",
    "smoke:vision": "node scripts/smoke/vision-providers.mjs",
    "bench:generate-cases": "node scripts/bench/generate-cases.mjs",
    "bench:seed": "node scripts/bench/seed.mjs",
    "bench:run": "node scripts/bench/run.mjs",
    "bench:clean": "node scripts/bench/clean.mjs",
    "bench:report": "node scripts/bench/report.mjs",
    "bench:compare": "node scripts/bench/compare.mjs",
    "build:tools-index": "node scripts/build-tools-index.mjs",
    "build:prompt-assembler": "node scripts/build-prompt-assembler.mjs",
    "build:packages": "pnpm --filter @dome/ai --filter @dome/agent-core --filter @dome/tools run build",
    "materialize:workspace-deps": "node scripts/materialize-workspace-deps.cjs",
    "verify:workspace-deps": "node scripts/verify-workspace-deps.cjs",
    "bench:rescore": "node scripts/bench/rescore-run.mjs",
    "bench:smoke": "node scripts/bench/run.mjs -- --case web_search.basic --mode direct",
    "bench:run:minimax": "node scripts/bench/run.mjs -- --provider minimax --mode direct --concurrency 1",
    "bench:run:openrouter": "node scripts/bench/run.mjs -- --provider openrouter --model anthropic/claude-3.5-sonnet --mode direct --concurrency 1",
    "clean": "bash scripts/clean.sh",
    "generate-icons": "tsx scripts/generate-icons.ts",
    "windows:startup-diag": "node scripts/windows-startup-diag.mjs",
    "restore:db": "node scripts/restore-db-backup.mjs"
  },
  "dependencies": {
    "@dome/agent-core": "workspace:*",
    "@dome/ai": "workspace:*",
    "@dome/i18n": "workspace:*",
    "@dome/prompts": "workspace:*",
    "@dome/tools": "workspace:*",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@floating-ui/react": "^0.27.19",
    "@lancedb/lancedb": "^0.21.3",
    "@langchain/core": "^1.1.40",
    "@langchain/mcp-adapters": "^1.1.3",
    "@mantine/core": "^8.3.14",
    "@mantine/hooks": "^8.3.14",
    "@mantine/notifications": "^8.3.14",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@napi-rs/canvas": "^0.1.97",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@sentry/electron": "^7.13.0",
    "@sinclair/typebox": "^0.34.49",
    "@tabler/icons-react": "^3.41.1",
    "@tiptap/core": "^3.22.4",
    "@tiptap/extension-bubble-menu": "^3.23.4",
    "@tiptap/extension-code-block-lowlight": "^3.22.3",
    "@tiptap/extension-collaboration": "^3.23.6",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-drag-handle": "^3.23.6",
    "@tiptap/extension-drag-handle-react": "^3.23.6",
    "@tiptap/extension-floating-menu": "^3.22.3",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-horizontal-rule": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-mention": "^3.22.3",
    "@tiptap/extension-node-range": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-table-cell": "^3.22.3",
    "@tiptap/extension-table-header": "^3.22.3",
    "@tiptap/extension-table-row": "^3.22.3",
    "@tiptap/extension-task-item": "^3.22.3",
    "@tiptap/extension-task-list": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-typography": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/extension-unique-id": "^3.22.3",
    "@tiptap/extension-youtube": "^3.22.3",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@tiptap/suggestion": "^3.22.3",
    "@tiptap/y-tiptap": "^3.0.3",
    "adm-zip": "^0.5.17",
    "apache-arrow": "^18.1.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.1.2",
    "chokidar": "^5.0.0",
    "clsx": "^2.1.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "driver.js": "^1.4.0",
    "electron-ollama": "^0.1.25",
    "electron-updater": "^6.7.3",
    "emoji-mart": "^5.6.0",
    "exceljs": "^4.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "html-to-docx": "^1.8.0",
    "i18next": "^25.10.10",
    "jotai": "^2.19.1",
    "jszip": "^3.10.1",
    "langfuse-langchain": "^3.38.20",
    "linkedom": "^0.18.12",
    "llm-chunk": "^0.0.1",
    "lowlight": "^3.1.0",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.11.0",
    "marked": "^17.0.6",
    "papaparse": "^5.5.3",
    "path-to-regexp": "^6.3.0",
    "pdfjs-dist": "^5.6.205",
    "picomatch": "^2.3.2",
    "posthog-js": "^1.372.1",
    "pptx-preview": "^1.0.7",
    "pptxgenjs": "^3.12.0",
    "protobufjs": "^7.6.4",
    "punycode": "^2.3.1",
    "pyodide": "^314.0.0",
    "react": "^18.3.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.0",
    "react-hotkeys-hook": "^5.2.4",
    "react-i18next": "^16.6.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "react-textarea-autosize": "^8.5.9",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.1",
    "ts-fsrs": "^5.4.1",
    "turndown": "^7.2.4",
    "yauzl": "^3.2.1",
    "yjs": "^13.6.30",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2",
    "zustand": "^4.5.7"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "protobufjs": "^7.6.4",
    "@protobufjs/utf8": "^1.1.1",
    "langsmith": "^0.6.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@electron/rebuild": "^4.0.4",
    "@sentry/vite-plugin": "^5.3.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "dependency-cruiser": "^16.0.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.9.0",
    "electron-devtools-installer": "^4.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "png2icons": "^2.0.1",
    "postcss": "^8.5.10",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "sass-embedded": "^1.99.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.2",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.domepro.app",
    "productName": "Dome",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "shared/**/*",
      "prompts/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,readme,test,__tests__,tests,powered-test,*.ts,*.map}",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/node_modules/*/{example,examples,doc,docs}"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "electron/dome-mcp-bridge.cjs",
      "node_modules/@ffmpeg-installer/**/*",
      "node_modules/@napi-rs/canvas/**/*",
      "node_modules/@napi-rs/canvas-*/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/archiver/**/*",
      "node_modules/archiver-utils/**/*",
      "node_modules/zip-stream/**/*",
      "node_modules/yauzl/**/*",
      "node_modules/@lancedb/lancedb/**/*",
      "node_modules/@lancedb/lancedb-*/**/*"
    ],
    "afterPack": "./scripts/after-pack.cjs",
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "maxprain12",
      "repo": "dome",
      "private": false
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "notarize": true
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon-256.png",
      "verifyUpdateCodeSignature": false
    },
    "portable": {
      "artifactName": "${productName}-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Office",
      "maintainer": "Dome Team <alder.velasquezobando@gmail.com>",
      "synopsis": "Knowledge management and academic research",
      "description": "Desktop app for knowledge management and academic research",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "flatpak",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "flatpak": {
      "runtime": "org.freedesktop.Platform",
      "runtimeVersion": "24.08",
      "sdk": "org.freedesktop.Sdk",
      "base": "org.electronjs.Electron2.BaseApp",
      "baseVersion": "24.08",
      "branch": "stable",
      "useWaylandFlags": true,
      "artifactName": "${productName}-${version}.${ext}",
      "finishArgs": [
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--share=network",
        "--device=dri",
        "--socket=pulseaudio",
        "--filesystem=home",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.freedesktop.portal.*",
        "--talk-name=org.kde.StatusNotifierWatcher",
        "--talk-name=com.canonical.AppMenu.Registrar"
      ]
    }
  }
}
