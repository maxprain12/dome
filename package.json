{
  "name": "dome",
  "version": "2.1.4",
  "description": "Aplicación de escritorio inteligente para gestión de conocimiento e investigación",
  "author": "Dome Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxprain12/dome"
  },
  "main": "electron/main.cjs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_OPTIONS=--max-old-space-size=8192 electron .\"",
    "electron:build": "npm run build && npm run rebuild:natives && npm run verify:natives && node scripts/prepare-pageindex-runtime.cjs && node scripts/embed-env.cjs && cross-env DEBUG= electron-builder",
    "electron:build:verbose": "npm run build && npm run rebuild:natives && npm run verify:natives && node scripts/prepare-pageindex-runtime.cjs && node scripts/embed-env.cjs && cross-env DEBUG=electron-builder electron-builder",
    "electron:pack": "cross-env DEBUG= electron-builder",
    "electron:pack:verbose": "cross-env DEBUG=electron-builder electron-builder",
    "prepare:pageindex-runtime": "node scripts/prepare-pageindex-runtime.cjs",
    "playwright:install": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium",
    "rebuild:natives": "electron-rebuild -f -w=better-sqlite3,sharp,@ffmpeg-installer/ffmpeg,@napi-rs/canvas,node-pty",
    "verify:natives": "node scripts/verify-natives.cjs",
    "copy:pdf-worker": "node scripts/copy-pdf-worker.cjs",
    "postinstall": "electron-builder install-app-deps && npm run rebuild:natives && npm run copy:pdf-worker && npm run playwright:install",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app/",
    "test:db": "tsx scripts/test-db.ts",
    "clean": "bash scripts/clean.sh",
    "generate-icons": "bun scripts/generate-icons.ts"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@floating-ui/dom": "^1.6.0",
    "@hono/node-server": "^1.19.13",
    "@joplin/turndown": "^4.0.82",
    "@joplin/turndown-plugin-gfm": "^1.0.64",
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.40",
    "@langchain/google-genai": "^2.1.27",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/ollama": "^1.2.2",
    "@langchain/openai": "^1.4.4",
    "@mantine/core": "^8.3.14",
    "@mantine/form": "^8.3.15",
    "@mantine/hooks": "^8.3.14",
    "@mantine/modals": "^8.3.14",
    "@mantine/notifications": "^8.3.14",
    "@mozilla/readability": "^0.6.0",
    "@napi-rs/canvas": "^0.1.88",
    "@sinclair/typebox": "^0.34.49",
    "@tabler/icons-react": "^3.41.1",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-bubble-menu": "^3.22.3",
    "@tiptap/extension-code-block-lowlight": "^3.22.3",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-dropcursor": "^3.22.3",
