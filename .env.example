# PostHog Analytics (opcional - para métricas de uso)
# Para builds en CI/CD: añadir VITE_POSTHOG_KEY como secret y VITE_POSTHOG_HOST como variable en GitHub Actions
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — errores, crashes nativos y rendimiento (opcional).
# El DSN es público por diseño (viaja en el cliente). Mismo DSN para main y renderer.
# Sentry respeta el toggle `analytics_enabled` de la app: si el usuario desactiva analytics, no se envía nada.
VITE_SENTRY_DSN=https://...@oXXXX.ingest.de.sentry.io/XXXX   # renderer (import.meta.env)
SENTRY_DSN=https://...@oXXXX.ingest.de.sentry.io/XXXX        # main process (process.env)
# Solo para BUILD/CI — subir source maps (NUNCA commitear el token real):
SENTRY_AUTH_TOKEN=
SENTRY_ORG=alder-dario-velasquez-obando
SENTRY_PROJECT=electron

# API Keys (Opcional - también se pueden configurar desde la UI)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Agent benchmark harness (pnpm run bench:run) — perfil aislado ~/.dome-bench
MINIMAX_BENCH_API_KEY=
OPENROUTER_BENCH_API_KEY=

# Configuración de desarrollo
NODE_ENV=development
VITE_ENABLE_DOME_PROVIDER=false

# Dome Provider (opcional — backend en ../dome-provider)
# Sin override: el main process usa http://localhost:3001 en dev y https://provider.dome.app si la app está empaquetada.
# DOME_PROVIDER_URL=http://localhost:3001

# URLs de modelos locales (Opcional)
LOCAL_MODEL_URL=http://localhost:11434

# Observabilidad — Langfuse (opcional; trazas LangGraph)
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASEURL=https://cloud.langfuse.com
# DOME_LANGFUSE_MASK=1
# DOME_LANGFUSE_MAX_STRING_CHARS=4000
# DOME_LANGFUSE_MAX_OBSERVATION_BYTES=131072
# DOME_LANGFUSE_SAMPLE_RATE=1
# DOME_LANGFUSE_ENVIRONMENT=default

# --- LangGraph agent middleware ---
# Actionable recovery hints appended to failing tool results
# (write_file denied → /memories/ + artifact_create; browser "No page found" → new_page).
# Set to 0 to disable.
# DOME_LANGGRAPH_TOOL_ERROR_HINTS=1

# Subagents Many can delegate to via the native `task` tool (parallel/specialized work).
# Comma-separated subset of: research,library,writer,data. Defaults to all four.
# Set to an empty value (DOME_MANY_SUBAGENTS=) to disable delegation in Many.
# DOME_MANY_SUBAGENTS=research,library,writer,data
