# PostHog Analytics (opcional - para métricas de uso)
# Para builds en CI/CD: añadir VITE_POSTHOG_KEY como secret y VITE_POSTHOG_HOST como variable en GitHub Actions
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://us.i.posthog.com

# API Keys (Opcional - también se pueden configurar desde la UI)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Configuración de desarrollo
NODE_ENV=development
VITE_ENABLE_DOME_PROVIDER=false

# URLs de modelos locales (Opcional)
LOCAL_MODEL_URL=http://localhost:11434
